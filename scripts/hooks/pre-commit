#!/bin/sh

# Pre-commit hook: auto-format and lint staged Python files with ruff.
# Install by running: scripts/setup-hooks.sh

# Common virtualenv bin directories used by this repo.
TOOL_ENV_BINS="./.pre-commit/bin ./.venv/bin /localdev/$USER/tt-metal/python_env/bin"

find_tool_in_env_bins() {
    tool_name="$1"
    for env_bin in $TOOL_ENV_BINS; do
        candidate="$env_bin/$tool_name"
        if [ -x "$candidate" ] && [ ! -d "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

RUFF=$(command -v ruff 2>/dev/null)
if [ -z "$RUFF" ]; then
    RUFF=$(find_tool_in_env_bins ruff)
fi

if [ -z "$RUFF" ]; then
    echo "⚠️  ruff not found, installing..."
    pip install --quiet ruff 2>/dev/null
    RUFF=$(command -v ruff 2>/dev/null)
    if [ -z "$RUFF" ]; then
        echo "❌ Failed to install ruff, skipping pre-commit checks"
        exit 0
    fi
    echo "✅ ruff installed successfully"
fi

# update default_model_spec.json and stage it
python3 -c 'from pathlib import Path; from workflows.model_spec import MODEL_SPECS, export_model_specs_json; export_model_specs_json(MODEL_SPECS, Path("default_model_spec.json"))'
if [ $? -ne 0 ]; then
    echo "❌ Failed to update default_model_spec.json"
    exit 1
fi
git add default_model_spec.json

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$')

if [ -z "$STAGED_FILES" ]; then
    echo "✅ No staged Python files, skipping Ruff checks and pytest"
    exit 0
fi

# Auto-fix what can be fixed
echo "$STAGED_FILES" | xargs "$RUFF" format
echo "$STAGED_FILES" | xargs "$RUFF" check --fix
echo "$STAGED_FILES" | xargs git add

# Now verify - same as CI does
echo "$STAGED_FILES" | xargs "$RUFF" check
if [ $? -ne 0 ]; then
    echo "❌ ruff check failed - fix errors above before committing"
    exit 1
fi

echo "$STAGED_FILES" | xargs "$RUFF" format --check
if [ $? -ne 0 ]; then
    echo "❌ ruff format failed - should not happen after auto-format"
    exit 1
fi

echo "✅ Ruff checks passed!"

PYTEST_PYTHON=""
PYTEST_PYTHON=$(find_tool_in_env_bins python3)
if [ -z "$PYTEST_PYTHON" ]; then
    PYTEST_PYTHON=$(find_tool_in_env_bins python)
fi

if [ -z "$PYTEST_PYTHON" ]; then
    echo "⚠️  No candidate virtualenv python found, skipping pytest"
else
    "$PYTEST_PYTHON" -m pytest -p no:warnings
    if [ $? -ne 0 ]; then
        echo "❌ pytest failed - fix errors above before committing"
        exit 1
    fi
    echo "✅ pytest passed!"
fi

echo "✅ All pre-commit checks passed!"
