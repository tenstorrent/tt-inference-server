{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workflow Reports Output",
  "description": "Schema for report_data_*.json generated by workflows/run_reports.py.",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "report_id": {
          "type": "string"
        },
        "model_name": {
          "type": "string"
        },
        "model_id": {
          "type": "string"
        },
        "runtime_model_spec_json": {
          "type": "string"
        },
        "model_repo": {
          "type": "string"
        },
        "model_impl": {
          "type": "string"
        },
        "inference_engine": {
          "type": "string"
        },
        "device": {
          "type": "string"
        },
        "server_mode": {
          "type": "string",
          "enum": [
            "API",
            "docker"
          ]
        },
        "tt_metal_commit": {
          "type": [
            "string",
            "null"
          ]
        },
        "vllm_commit": {
          "type": [
            "string",
            "null"
          ]
        },
        "run_command": {
          "type": "string"
        }
      },
      "required": [
        "report_id",
        "model_name",
        "model_id",
        "runtime_model_spec_json",
        "model_repo",
        "model_impl",
        "inference_engine",
        "device",
        "server_mode",
        "tt_metal_commit",
        "vllm_commit",
        "run_command"
      ],
      "additionalProperties": false
    },
    "benchmarks_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "aiperf_benchmarks": {
      "type": "array",
      "items": {}
    },
    "evals": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "additionalProperties": true
              }
            ]
          }
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "stress_tests": {
      "type": [
        "array",
        "object",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      },
      "additionalProperties": true
    },
    "benchmarks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "aiperf_benchmarks_detailed": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "parameter_support_tests": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      ]
    },
    "spec_tests": {
      "type": "object",
      "additionalProperties": true
    },
    "benchmark_target_evaluation": {
      "type": "object",
      "additionalProperties": true
    },
    "acceptance_criteria": {
      "type": "boolean"
    },
    "acceptance_blockers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "acceptance_summary_markdown": {
      "type": "string"
    }
  },
  "required": [
    "metadata",
    "benchmarks_summary",
    "aiperf_benchmarks",
    "evals",
    "stress_tests",
    "benchmarks",
    "aiperf_benchmarks_detailed",
    "parameter_support_tests",
    "spec_tests",
    "benchmark_target_evaluation",
    "acceptance_criteria",
    "acceptance_blockers",
    "acceptance_summary_markdown"
  ],
  "additionalProperties": false
}
