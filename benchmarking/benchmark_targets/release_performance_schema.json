{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Release Performance Baseline",
  "description": "Schema for benchmarking/benchmark_targets/release_performance.json generated by scripts/release/generate_release_artifacts.py --release.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "models"
  ],
  "$defs": {
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "nullable_boolean": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "nullable_integer": {
      "type": [
        "integer",
        "null"
      ]
    },
    "nullable_number": {
      "type": [
        "number",
        "null"
      ]
    },
    "perf_status": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "experimental",
        "functional",
        "complete",
        "target",
        null
      ]
    },
    "failure": {
      "type": "object",
      "properties": {
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "key",
        "message"
      ],
      "additionalProperties": true
    },
    "support_level_result": {
      "type": "object",
      "properties": {
        "checked": {
          "type": "boolean"
        },
        "passed": {
          "type": "boolean"
        },
        "failures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failure"
          }
        }
      },
      "additionalProperties": false
    },
    "benchmark_target_evaluation": {
      "type": "object",
      "properties": {
        "reference_available": {
          "type": "boolean"
        },
        "status": {
          "$ref": "#/$defs/perf_status"
        },
        "support_levels": {
          "type": "object",
          "properties": {
            "functional": {
              "$ref": "#/$defs/support_level_result"
            },
            "complete": {
              "$ref": "#/$defs/support_level_result"
            },
            "target": {
              "$ref": "#/$defs/support_level_result"
            }
          },
          "additionalProperties": false
        },
        "regression": {
          "$ref": "#/$defs/support_level_result"
        },
        "next_status": {
          "$ref": "#/$defs/perf_status"
        },
        "next_status_failures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failure"
          }
        },
        "errors": {
          "type": "array",
          "items": {}
        }
      },
      "additionalProperties": true
    },
    "parameter_support_test_result": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "test_node_name": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "status"
      ],
      "additionalProperties": true
    },
    "parameter_support_tests": {
      "type": "object",
      "properties": {
        "endpoint_url": {
          "type": "string"
        },
        "test_run_timestamp_utc": {
          "type": "string"
        },
        "results": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/parameter_support_test_result"
            }
          }
        }
      },
      "additionalProperties": true
    },
    "benchmark_target_check": {
      "type": "object",
      "additionalProperties": true
    },
    "benchmark_row": {
      "type": "object",
      "properties": {
        "task_type": {
          "type": "string"
        },
        "isl": {
          "$ref": "#/$defs/nullable_integer"
        },
        "osl": {
          "$ref": "#/$defs/nullable_integer"
        },
        "input_sequence_length": {
          "$ref": "#/$defs/nullable_integer"
        },
        "output_sequence_length": {
          "$ref": "#/$defs/nullable_integer"
        },
        "max_concurrency": {
          "$ref": "#/$defs/nullable_integer"
        },
        "max_con": {
          "$ref": "#/$defs/nullable_integer"
        },
        "concurrency": {
          "$ref": "#/$defs/nullable_integer"
        },
        "num_requests": {
          "$ref": "#/$defs/nullable_integer"
        },
        "num_eval_runs": {
          "$ref": "#/$defs/nullable_integer"
        },
        "num_inference_steps": {
          "$ref": "#/$defs/nullable_integer"
        },
        "image_height": {
          "$ref": "#/$defs/nullable_integer"
        },
        "image_width": {
          "$ref": "#/$defs/nullable_integer"
        },
        "images_per_prompt": {
          "$ref": "#/$defs/nullable_integer"
        },
        "images": {
          "$ref": "#/$defs/nullable_integer"
        },
        "ttft": {
          "$ref": "#/$defs/nullable_number"
        },
        "mean_ttft_ms": {
          "$ref": "#/$defs/nullable_number"
        },
        "tput_user": {
          "$ref": "#/$defs/nullable_number"
        },
        "mean_tps": {
          "$ref": "#/$defs/nullable_number"
        },
        "tput": {
          "$ref": "#/$defs/nullable_number"
        },
        "tps_decode_throughput": {
          "$ref": "#/$defs/nullable_number"
        },
        "ttft_streaming_ms": {
          "$ref": "#/$defs/nullable_number"
        },
        "tput_prefill": {
          "$ref": "#/$defs/nullable_number"
        },
        "tps_prefill_throughput": {
          "$ref": "#/$defs/nullable_number"
        },
        "e2el_ms": {
          "$ref": "#/$defs/nullable_number"
        },
        "mean_e2el_ms": {
          "$ref": "#/$defs/nullable_number"
        },
        "rtr": {
          "$ref": "#/$defs/nullable_number"
        },
        "target_checks": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/benchmark_target_check"
          }
        }
      },
      "additionalProperties": true
    },
    "perf_target_config": {
      "type": "object",
      "properties": {
        "task_type": {
          "type": "string"
        },
        "isl": {
          "$ref": "#/$defs/nullable_integer"
        },
        "osl": {
          "$ref": "#/$defs/nullable_integer"
        },
        "max_concurrency": {
          "$ref": "#/$defs/nullable_integer"
        },
        "num_eval_runs": {
          "$ref": "#/$defs/nullable_integer"
        },
        "num_inference_steps": {
          "$ref": "#/$defs/nullable_integer"
        },
        "image_height": {
          "$ref": "#/$defs/nullable_integer"
        },
        "image_width": {
          "$ref": "#/$defs/nullable_integer"
        },
        "images_per_prompt": {
          "$ref": "#/$defs/nullable_integer"
        }
      },
      "required": [
        "task_type",
        "isl",
        "osl",
        "max_concurrency"
      ],
      "additionalProperties": false
    },
    "measured_metrics": {
      "type": "object",
      "properties": {
        "ttft": {
          "$ref": "#/$defs/nullable_number"
        },
        "tput_user": {
          "$ref": "#/$defs/nullable_number"
        },
        "tput": {
          "$ref": "#/$defs/nullable_number"
        },
        "ttft_streaming_ms": {
          "$ref": "#/$defs/nullable_number"
        },
        "tput_prefill": {
          "$ref": "#/$defs/nullable_number"
        },
        "e2el_ms": {
          "$ref": "#/$defs/nullable_number"
        },
        "rtr": {
          "$ref": "#/$defs/nullable_number"
        }
      },
      "required": [
        "ttft",
        "tput_user",
        "tput",
        "ttft_streaming_ms",
        "tput_prefill",
        "e2el_ms",
        "rtr"
      ],
      "additionalProperties": false
    },
    "summary_targets": {
      "type": "object",
      "properties": {
        "ttft_ms": {
          "$ref": "#/$defs/nullable_number"
        },
        "ttft_streaming_ms": {
          "$ref": "#/$defs/nullable_number"
        },
        "tput_user": {
          "$ref": "#/$defs/nullable_number"
        },
        "tput_prefill": {
          "$ref": "#/$defs/nullable_number"
        },
        "e2el_ms": {
          "$ref": "#/$defs/nullable_number"
        },
        "tput": {
          "$ref": "#/$defs/nullable_number"
        },
        "rtr": {
          "$ref": "#/$defs/nullable_number"
        },
        "tolerance": {
          "$ref": "#/$defs/nullable_number"
        }
      },
      "required": [
        "ttft_ms",
        "ttft_streaming_ms",
        "tput_user",
        "tput_prefill",
        "e2el_ms",
        "tput",
        "rtr",
        "tolerance"
      ],
      "additionalProperties": false
    },
    "perf_target_result": {
      "type": "object",
      "properties": {
        "is_summary_data_point": {
          "type": "boolean"
        },
        "config": {
          "$ref": "#/$defs/perf_target_config"
        },
        "targets": {
          "$ref": "#/$defs/summary_targets"
        },
        "measured_metrics": {
          "$ref": "#/$defs/measured_metrics"
        },
        "benchmark_summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/benchmark_row"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "is_summary_data_point",
        "config",
        "targets",
        "measured_metrics",
        "benchmark_summary"
      ],
      "additionalProperties": false
    },
    "report_data": {
      "type": "object",
      "properties": {
        "benchmarks_summary": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/benchmark_row"
          }
        },
        "benchmark_target_evaluation": {
          "$ref": "#/$defs/benchmark_target_evaluation"
        },
        "parameter_support_tests": {
          "$ref": "#/$defs/parameter_support_tests"
        }
      },
      "additionalProperties": true
    },
    "entry": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string"
        },
        "device": {
          "type": "string"
        },
        "impl_id": {
          "type": "string"
        },
        "inference_engine": {
          "type": "string"
        },
        "perf_status": {
          "$ref": "#/$defs/perf_status"
        },
        "accuracy_status": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "ci_run_number": {
          "$ref": "#/$defs/nullable_integer"
        },
        "ci_run_url": {
          "$ref": "#/$defs/nullable_string"
        },
        "ci_job_url": {
          "$ref": "#/$defs/nullable_string"
        },
        "benchmarks_summary": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/benchmark_row"
          }
        },
        "perf_target_results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/perf_target_result"
          }
        },
        "perf_target_summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/perf_target_result"
            },
            {
              "type": "null"
            }
          ]
        },
        "report_data": {
          "$ref": "#/$defs/report_data"
        }
      },
      "required": [
        "model",
        "device",
        "impl_id",
        "inference_engine",
        "perf_status",
        "accuracy_status",
        "ci_run_number",
        "ci_run_url",
        "ci_job_url",
        "benchmarks_summary",
        "perf_target_results",
        "perf_target_summary",
        "report_data"
      ],
      "additionalProperties": false
    },
    "inference_engine_map": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/entry"
      }
    },
    "impl_map": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/inference_engine_map"
      }
    },
    "device_map": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/impl_map"
      }
    }
  },
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "models": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/device_map"
      }
    }
  }
}
