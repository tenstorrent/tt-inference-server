# Defaults for the `guidellm_sweep` test variant. Mirrors the
# guidellmSweep: block of the old chart's values.yaml.

: "${MODEL:=deepseek-ai/DeepSeek-R1-0528}"
: "${PROCESSOR:=deepseek-ai/DeepSeek-R1-0528}"
: "${RATES:=1,2,4,8,16,32,64,128}"
