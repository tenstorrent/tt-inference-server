#
# Defaults for the `summarize_bench` test variant. Mirrors the
# summarizeBench: block of the old chart's values.yaml. DATASET_PATH defaults
# to the prompts_32k.jsonl shipped alongside run.sh.

: "${MODEL:=deepseek-ai/DeepSeek-R1-0528}"
: "${OUTPUT_LEN:=1024}"
: "${NUM_PROMPTS:=1}"
: "${MAX_CONCURRENCY:=1}"
: "${REQUEST_TIMEOUT_SEC:=1800}"
: "${RESULT_NAME:=summarize_32k}"
: "${DATASET_PATH:=}"   # resolved by run.sh to sibling prompts_32k.jsonl if empty
