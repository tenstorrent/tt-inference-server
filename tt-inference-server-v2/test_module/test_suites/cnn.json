{
    "_description": "Test suites for CNN model category",
    "_category": "CNN",
    "test_matrices": [
        {
            "models": [
                "mobilenetv2",
                "resnet",
                "efficientnet",
                "segformer",
                "unet",
                "vit",
                "vovnet"
            ],
            "devices": [
                "n150",
                "n300"
            ],
            "num_of_devices": 1,
            "test_cases": [
                {
                    "template": "CnnLoadTest",
                    "enabled": true,
                    "description": "CNN image classification load test",
                    "targets": {
                        "cnn_time": 5,
                        "response_format": "json",
                        "top_k": 3,
                        "min_confidence": 70.0
                    }
                },
                {
                    "template": "CnnParamTest",
                    "enabled": true,
                    "description": "CNN parameter variations test"
                }
            ]
        }
    ]
}
