{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Kill C++ Server",
            "type": "shell",
            "command": "pkill -9 -f tt_media_server_cpp || true",
            "options": { "cwd": "${workspaceFolder}" },
            "presentation": { "reveal": "silent", "panel": "shared" }
        },
        {
            "label": "Build C++ Server (debug)",
            "type": "shell",
            "command": "./build.sh",
            "args": ["--debug"],
            "options": { "cwd": "${workspaceFolder}/cpp_server" },
            "group": "build",
            "dependsOn": ["Kill C++ Server"],
            "presentation": { "reveal": "silent", "panel": "shared" }
        }
    ]
}
