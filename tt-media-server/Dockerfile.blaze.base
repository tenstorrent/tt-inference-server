# ==============================================================================
# BASE IMAGE for Dockerfile.blaze
# ==============================================================================
# Contains the heavy, slow-changing pieces of the blaze image:
#   - system / apt deps + CMake (build-time)
#   - cpp_server build deps + Drogon (via install_dependencies.sh)
#   - Rust toolchain
#   - tt-blaze + tt-metal fully built
#   - runtime apt deps (ffmpeg, gosu, libjsoncpp-dev) + container_app_user
#     account + bashrc — moved here from a separate runtime stage so the
#     derived image can be SINGLE-STAGE.
#
# Total build time of this image is ~25 minutes; rebuilt on demand (typically
# when the tt-blaze branch is bumped). Dockerfile.blaze derives from this
# image via FROM ${BASE_IMAGE} and only adds the cpp_server build, so its
# layers are inherited from this base — already-pushed digests are skipped
# by `docker push`, and only the small cpp_server delta layer ships. This is
# what gets cpp_server-only rebuilds (the common case) down to ~7-10 min:
# without inheriting layer digests from the base, the derived push squashes
# everything into a single ~5GB content-addressed layer that the registry
# never has and always re-pushes (~25 min — see tt-shield run 25308875892).
#
# Trade-off: the final image carries build deps (rust, .cpmcache, etc.) that
# the previous multi-stage runtime would have stripped. Image size grows by
# a few GB but warm rebuilds drop from ~48 min to ~7-10 min. For the user's
# stated goal (fastest cpp_server iteration) that's the right trade-off.
#
# Why a separate image instead of BuildKit registry cache: tt-shield ARC
# runner pods don't share docker daemon state, so daemon-local layer cache
# is a pod-affinity coin flip; and BuildKit's docker-container driver can't
# reach ghcr.io from these pods even with network=host (see tt-shield runs
# 25301564690 / 25301890873). A plain `FROM ghcr.io/...` works fine because
# it goes through the host docker daemon, which CAN reach ghcr.io.
#
# Tag convention used by CI:
#   <repo>/tt-media-inference-server-blaze-base:<sanitized-branch>
# (slashes in TT_BLAZE_BRANCH are replaced with '-' to satisfy OCI tag rules).
# ==============================================================================
FROM ghcr.io/tenstorrent/tt-metal/tt-metalium/ubuntu-22.04-dev-amd64:latest

LABEL maintainer="Igor Djuric <idjuric@tenstorrent.com>"
LABEL org.opencontainers.image.source=https://github.com/tenstorrent/tt-inference-server

ARG DEBIAN_FRONTEND=noninteractive
# Informational only at base-image level; the tt-metal version actually
# built comes from the tt-blaze submodule pin on TT_BLAZE_BRANCH.
ARG TT_METAL_COMMIT_SHA_OR_TAG=915d9e67ad572b97fbaf5339bd3e518db6dc05e3
ENV TT_METAL_COMMIT_SHA_OR_TAG=${TT_METAL_COMMIT_SHA_OR_TAG}

ENV ENVIRONMENT=development
ENV TT_MM_THROTTLE_PERF=5

ENV SHELL=/bin/bash
ENV CONTAINER_APP_USERNAME=container_app_user
# HOME_DIR is exported as ENV so derived images (Dockerfile.blaze) can
# reference ${HOME_DIR} after FROM ${BASE_IMAGE}. ARGs are not inherited.
ENV HOME_DIR=/home/${CONTAINER_APP_USERNAME}

# tt-metal build vars (kept for compatibility with the original image layout)
ENV TT_METAL_HOME=${HOME_DIR}/tt-metal
ENV CONFIG=Release
ENV TT_METAL_ENV=dev
ENV LOGURU_LEVEL=INFO
ENV PYTHONPATH=${TT_METAL_HOME}
ENV PYTHON_ENV_DIR=${TT_METAL_HOME}/python_env
ENV LD_LIBRARY_PATH=${TT_METAL_HOME}/build/lib

# apt-get keyring refresh for cmake repo
RUN wget -O - https://apt.kitware.com/keys/kitware-archive-latest.asc 2>/dev/null | gpg --dearmor - | tee /usr/share/keyrings/kitware-archive-keyring.gpg >/dev/null \
    && echo 'deb [signed-by=/usr/share/keyrings/kitware-archive-keyring.gpg] https://apt.kitware.com/ubuntu/ focal main' | tee /etc/apt/sources.list.d/kitware.list >/dev/null

# Tell apt to retry transient HTTP failures. The tt-shield runner's in-cluster
# apt proxy (10.43.242.248:3128) intermittently times out — without this,
# apt's first failure on archive.ubuntu.com causes the whole `apt-get install`
# to fall back to stale package lists and report "Unable to locate package
# htop / Package 'zip' has no installation candidate" (cf. tt-shield runs
# 25325113617, 25326963035, 25338811255). Retries=5 + Retries-Delay=5 lets
# apt ride through ~25 seconds of proxy flakiness without faking success.
RUN printf 'Acquire::Retries "5";\nAcquire::Retries::Delay::Maximum "5";\nAcquire::http::Timeout "60";\nAcquire::https::Timeout "60";\n' > /etc/apt/apt.conf.d/80-retries

# extra system deps (same set as the original Dockerfile.blaze pre-split)
RUN apt-get update && apt-get install -y \
    gosu \
    libgl1 \
    libsndfile1 \
    wget \
    git-lfs \
    nano \
    acl \
    jq \
    vim \
    # pyluwen build dependencies (Rust package with protobuf)
    build-essential \
    python3-dev \
    libffi-dev \
    libssl-dev \
    protobuf-compiler \
    libprotobuf-dev \
    pkg-config \
    htop \
    screen \
    tmux \
    unzip \
    zip \
    curl \
    iputils-ping \
    rsync \
    && rm -rf /var/lib/apt/lists/* \
    && protoc --version

# CMake 3.26.4 for CMP0169 compatibility
RUN curl -fsSL https://github.com/Kitware/CMake/releases/download/v3.26.4/cmake-3.26.4-linux-x86_64.sh -o cmake.sh \
    && chmod +x cmake.sh \
    && ./cmake.sh --skip-license --prefix=/usr/local \
    && rm cmake.sh \
    && /usr/local/bin/cmake --version

RUN mkdir -p ${HOME_DIR} \
    && mkdir -p /run/sshd \
    && chmod 755 /run/sshd

RUN echo "source ${PYTHON_ENV_DIR}/bin/activate" >> ${HOME_DIR}/.bashrc

WORKDIR ${HOME_DIR}

ENV APP_DIR=${HOME_DIR}/app
WORKDIR ${APP_DIR}

# ----------------------------------------------------------------------------
# cpp_server build deps (apt + Drogon) + Rust toolchain.
# Only install_dependencies.sh is COPYd here so this layer is keyed on
# the script content, not unrelated cpp_server source. CARGO_HOME and
# RUSTUP_HOME steer rustup-init into HOME_DIR; PATH ensures cargo is
# discoverable for tt-blaze's pipeline_manager cmake step (which
# silently skips deepseek_inference_runner if cargo is not on PATH and
# then later tries to make the missing target — see tt-shield job
# 74174444965).
# ----------------------------------------------------------------------------
ENV CARGO_HOME=${HOME_DIR}/.cargo \
    RUSTUP_HOME=${HOME_DIR}/.rustup
ENV PATH=${CARGO_HOME}/bin:${PATH}
COPY tt-media-server/cpp_server/install_dependencies.sh /tmp/install_dependencies.sh
RUN /tmp/install_dependencies.sh && rm -f /tmp/install_dependencies.sh

# ----------------------------------------------------------------------------
# Clone + build tt-blaze (and tt-metal). This is the ~10-minute step the
# whole base image exists to amortize. Branch comes from a build-arg so the
# same Dockerfile.blaze.base can produce per-branch base images.
# ----------------------------------------------------------------------------
ARG TT_BLAZE_BRANCH=asaigal/ds_pm_integration
ENV TT_BLAZE_BRANCH=${TT_BLAZE_BRANCH}
RUN --mount=type=secret,id=github_token \
    mkdir -p ${APP_DIR}/server/cpp_server \
    && rm -rf ${APP_DIR}/server/cpp_server/tt-blaze \
    && GITHUB_TOKEN=$(cat /run/secrets/github_token) \
    && git config --global url."https://x-access-token:${GITHUB_TOKEN}@github.com/".insteadOf "git@github.com:" \
    && git clone --depth 1 --branch ${TT_BLAZE_BRANCH} https://x-access-token:${GITHUB_TOKEN}@github.com/tenstorrent/tt-blaze.git ${APP_DIR}/server/cpp_server/tt-blaze \
    && cd ${APP_DIR}/server/cpp_server/tt-blaze \
    && git submodule update --init --recursive --depth 1 || echo "Some submodules failed, continuing..." \
    && ./install.sh \
    && . ./env.sh \
    && (cd tt-metal && ./build_metal.sh --disable-profiler) \
    && ./pipeline_manager/setup.sh --pm-full \
    && git config --global --unset url."https://x-access-token:${GITHUB_TOKEN}@github.com/".insteadOf

# Trim the largest non-runtime tt-metal artifacts so every derived image
# inherits a smaller starting point. .cpmcache and the tt-metal build
# outputs and python venv stay — needed at runtime / cpp_server build.
RUN rm -rf ${APP_DIR}/server/cpp_server/tt-blaze/tt-metal/docs \
    && rm -rf ${APP_DIR}/server/cpp_server/tt-blaze/tt-metal/tests \
    && rm -rf ${APP_DIR}/server/cpp_server/tt-blaze/tt-metal/tech_reports \
    && rm -rf ${APP_DIR}/server/cpp_server/tt-blaze/tt-metal/.github

# ----------------------------------------------------------------------------
# Runtime bits (previously lived in a separate runtime stage in Dockerfile.blaze).
# Placed here so the derived image can be single-stage and inherit ALL these
# layer digests directly from this base — `docker push` of the derived image
# then only ships the small cpp_server build delta on top.
# ----------------------------------------------------------------------------

# Extra runtime apt deps (gosu is already in the system-deps RUN above; no need
# to reinstall). ffmpeg is needed for the python uvicorn server's media path
# (also harmless in the C++-only blaze image — kept for parity).
ARG DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y \
    ffmpeg \
    libjsoncpp-dev \
    && rm -rf /var/lib/apt/lists/*

# Create the non-root container user. UID 1000 matches the convention used by
# the rest of the tt-* docker images (tt-inference-server, etc.) and by the
# k8s manifests that mount host volumes into these containers. We do this AT
# THE END (not at the start) on purpose: the heavy build steps above run as
# root, so their files end up root-owned. A single chown -R afterwards bakes
# the correct ownership into ONE layer in the base image; derived images
# inherit that layer for free and only need to chown the small cpp_server
# delta they add. (If we chown'd up front, every subsequent RUN as root
# would re-create root-owned files and we'd be back to square one.)
ARG CONTAINER_APP_UID=1000
RUN useradd -u ${CONTAINER_APP_UID} -s /bin/bash -d ${HOME_DIR} -M ${CONTAINER_APP_USERNAME} \
    && mkdir -p ${HOME_DIR}/logs \
    && chown -R ${CONTAINER_APP_USERNAME}:${CONTAINER_APP_USERNAME} ${HOME_DIR}
ENV TT_METAL_LOGS_PATH=${HOME_DIR}/logs

# Runtime layout vars Dockerfile.blaze and downstream consumers rely on.
# Point TT_METAL_HOME at the tt-blaze copy of tt-metal (built above);
# the original Dockerfile.blaze multi-stage runtime stage did the same.
# Override the base's earlier ${HOME_DIR}/tt-metal pointer set at the top
# of this file (which was for the build-time tt-metal layout).
ENV TT_METAL_HOME=${APP_DIR}/server/cpp_server/tt-blaze/tt-metal \
    TT_METAL_RUNTIME_ROOT=${APP_DIR}/server/cpp_server/tt-blaze/tt-metal \
    PYTHONPATH=${APP_DIR}/server/cpp_server/tt-blaze/tt-metal \
    LD_LIBRARY_PATH=${APP_DIR}/server/cpp_server/tt-blaze/tt-metal/build/lib
