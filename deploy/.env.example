# tt-inference-server Docker Compose environment variables
# Copy to .env and fill in values before running docker compose.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose -f docker-compose.vllm.yml up -d

# =============================================================================
# Secrets (required)
# =============================================================================
HF_TOKEN=                          # HuggingFace token for model downloads
JWT_SECRET=                        # JWT secret for API authentication (optional with --no-auth)

# =============================================================================
# Common (required for all engines)
# =============================================================================
DOCKER_IMAGE=                      # Docker image (e.g. ghcr.io/tenstorrent/tt-inference-server/vllm-tt-metal-src-release-ubuntu-22.04-amd64:0.9.0-xxx)

# =============================================================================
# Common (optional, have defaults)
# =============================================================================
# CONTAINER_NAME=tt-inference-server  # Container name
# SERVICE_PORT=8000                   # API port
# BIND_HOST=0.0.0.0                  # Host interface to bind
# CACHE_ROOT=/home/container_app_user/cache_root  # Cache root inside container
# CACHE_VOLUME=tt-inference-cache    # Docker named volume for cache (or host path)
# ENV_FILE=.env                      # Path to env file

# =============================================================================
# vLLM engine (docker-compose.vllm.yml)
# =============================================================================
HF_MODEL=                          # HuggingFace model repo (e.g. meta-llama/Llama-3.1-8B-Instruct)
TT_DEVICE=                         # Tenstorrent device type (e.g. n150, t3k, galaxy)

# =============================================================================
# Media/Forge engine (docker-compose.media.yml)
# =============================================================================
# MODEL=                            # Model name (e.g. Wan2.2-T2V-A14B-Diffusers)
# DEVICE=                           # Device name (e.g. galaxy, t3k)

# =============================================================================
# Multi-host (docker-compose.multihost-*.yml)
# =============================================================================
# SHARED_STORAGE_ROOT=              # Shared filesystem path (e.g. /mnt/shared)
# MULTIHOST_HOSTS=                  # Comma-separated hostnames (e.g. host1,host2)
# MPI_INTERFACE=                    # MPI network interface (e.g. cnx1)
# MESH_DEVICE=                      # Mesh device string (e.g. (8,8) for Dual Galaxy)
# SSH_CONFIG_DIR=                   # Path to SSH config directory (generated by orchestrator)
# MPIRUN_DIR=                       # Path to MPI rankfile directory (generated by orchestrator)
# RUNTIME_MODEL_SPEC_JSON=          # Path to merged runtime model spec JSON
# SSH_PORT=2200                     # Worker SSH port
